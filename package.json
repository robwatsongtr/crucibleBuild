{
  "name": "cruciblebuild",
  "version": "1.0.0",
  "description": "Project-based technical mentorship CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cruciblebuild": "bin/cruciblebuild"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robwatsongtr/crucibleBuild-.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/robwatsongtr/crucibleBuild-/issues"
  },
  "homepage": "https://github.com/robwatsongtr/crucibleBuild-#readme",
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^25.9.2",
    "@types/wrap-ansi": "^8.0.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/snapshot": "^4.1.8",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@google/genai": "^2.8.0",
    "@types/marked": "^5.0.2",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "marked": "^4.3.0",
    "marked-terminal": "^5.2.0",
    "wrap-ansi": "^10.0.0",
    "zod": "^4.4.3"
  }
}
